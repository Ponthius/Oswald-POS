<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"] - Oswald POS</title>
    <style>
        body {
            margin: 0;
            font-family: Segoe UI, Arial;
            background: #f3f4f6;
            color: #111827;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: #111827;
            color: white;
            padding: 25px 18px;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 35px;
            color: #facc15;
        }

        .sidebar a {
            display: block;
            color: #d1d5db;
            text-decoration: none;
            padding: 13px 15px;
            border-radius: 12px;
            margin-bottom: 8px;
        }

        .sidebar a:hover {
            background: #4f46e5;
            color: white;
        }

        .main {
            flex: 1;
        }

        .topbar {
            background: white;
            padding: 18px 28px;
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
            display: flex;
            justify-content: space-between;
        }

        .content {
            padding: 28px;
        }

        .logout {
            color: #dc2626;
            text-decoration: none;
            font-weight: bold;
        }

        .nav-icon {
    display: inline-flex;
    width: 24px;
    height: 24px;
    background: #374151;
    color: #facc15;
    border-radius: 6px;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 900;
    margin-right: 8px;
}
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <div class="logo">Oswald POS</div>

            <a href="/Dashboard"><span class="nav-icon">D</span> Dashboard</a>
<a href="/Sales"><span class="nav-icon">S</span> POS Sales</a>
<a href="/Sales/History"><span class="nav-icon">H</span> Sales History</a>
<a href="/Products"><span class="nav-icon">P</span> Products</a>
<a href="/Categories"><span class="nav-icon">C</span> Categories</a>
<a href="/Customers"><span class="nav-icon">U</span> Customers</a>
<a href="/Workers"><span class="nav-icon">W</span> Workers</a>
        </aside>

        <main class="main">
            <div class="topbar">
                <strong>@ViewData["Title"]</strong>
                <a class="logout" href="/Account/Logout">Logout</a>
            </div>

            <div class="content">
                @RenderBody()
            </div>
        </main>
    </div>
</body>
</html>