@model List<Oswald_POS.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<style>
    .grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 20px;
    }

    .panel {
        background: white;
        border-radius: 10px;
        padding: 22px;
        border: 1px solid #dbe1ea;
        box-shadow: 0 8px 24px rgba(15,23,42,.06);
    }

    input, button {
        width: 100%;
        box-sizing: border-box;
        padding: 12px;
        margin-bottom: 10px;
        border-radius: 7px;
        border: 1px solid #cbd5e1;
    }

    button {
        border: none;
        background: #2563eb;
        color: white;
        font-weight: 800;
        cursor: pointer;
    }

    .delete {
        background: #dc2626;
    }

    .category-card {
        display: grid;
        grid-template-columns: 80px 1fr 160px;
        gap: 12px;
        align-items: center;
        padding: 14px;
        border-bottom: 1px solid #e5e7eb;
    }

    .color-box {
        width: 55px;
        height: 55px;
        border-radius: 10px;
    }

    .actions {
        display: flex;
        gap: 8px;
    }

    .actions button {
        margin: 0;
    }

    .error {
        background: #fee2e2;
        color: #991b1b;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 15px;
        font-weight: bold;
    }
</style>

@if (TempData["Error"] != null)
{
    <div class="error">@TempData["Error"]</div>
}

<div class="grid">
    <div class="panel">
        <h2>Add Category</h2>

        <form method="post" action="/Categories/Create">
            <input name="Name" placeholder="Category name" required />
            <input type="color" name="Color" value="#4f46e5" />
            <button type="submit">Save Category</button>
        </form>
    </div>

    <div class="panel">
        <h2>Manage Categories</h2>

        @foreach (var item in Model)
        {
            var formId = "categoryForm" + item.Id;

            <div class="category-card">
                <div class="color-box" style="background:@item.Color"></div>

                <div>
                    <input form="@formId" type="hidden" name="Id" value="@item.Id" />
                    <input form="@formId" name="Name" value="@item.Name" />
                    <input form="@formId" type="color" name="Color" value="@item.Color" />
                    <small>@item.Products.Count product(s)</small>
                </div>

                <div class="actions">
                    <form id="@formId" method="post" action="/Categories/Update"></form>

                    <button form="@formId" type="submit">Update</button>

                    <form method="post" action="/Categories/Delete/@item.Id"
                          onsubmit="return confirm('Delete this category? Categories with products cannot be deleted.')">
                        <button class="delete" type="submit">Delete</button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>