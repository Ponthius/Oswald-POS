@model List<Oswald_POS.Models.Sale>

@{
    ViewData["Title"] = "Sales History";
}

<style>
    .history-card {
        background: white;
        border-radius: 8px;
        border: 1px solid #dbe1ea;
        box-shadow: 0 8px 24px rgba(15,23,42,.06);
        overflow: hidden;
    }

    .toolbar {
        padding: 15px;
        background: #f8fafc;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .toolbar input {
        padding: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        width: 320px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #f8fafc;
        color: #475569;
        text-align: left;
        padding: 13px;
        font-size: 13px;
        border-bottom: 1px solid #e5e7eb;
    }

    td {
        padding: 13px;
        border-bottom: 1px solid #e5e7eb;
    }

    .badge-paid {
        background: #dcfce7;
        color: #166534;
        padding: 5px 9px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: bold;
    }

    .badge-void {
        background: #fee2e2;
        color: #991b1b;
        padding: 5px 9px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: bold;
    }

    .btn {
        padding: 8px 10px;
        border-radius: 5px;
        border: none;
        text-decoration: none;
        font-size: 13px;
        cursor: pointer;
        font-weight: 700;
    }

    .btn-view {
        background: #2563eb;
        color: white;
    }

    .btn-download {
        background: #111827;
        color: white;
    }

    .btn-void {
        background: #dc2626;
        color: white;
    }

    .actions {
        display: flex;
        gap: 6px;
        align-items: center;
    }
</style>

<div class="history-card">
    <div class="toolbar">
        <strong>All Sales</strong>
        <input id="searchBox" placeholder="Search receipt, customer, cashier, payment..." onkeyup="filterTable()" />
    </div>

    <table id="salesTable">
        <thead>
            <tr>
                <th>Receipt</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Cashier</th>
                <th>Payment</th>
                <th>Total</th>
                <th>Paid</th>
                <th>Change</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var sale in Model)
            {
                <tr>
                    <td>@sale.ReceiptNumber</td>
                    <td>@sale.SaleDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@(sale.Customer?.FullName ?? "Walk-in")</td>
                    <td>@(sale.Worker?.FullName ?? "Unknown")</td>
                    <td>@sale.PaymentMethod</td>
                    <td>UGX @sale.TotalAmount.ToString("N0")</td>
                    <td>UGX @sale.AmountPaid.ToString("N0")</td>
                    <td>UGX @sale.Change.ToString("N0")</td>
                    <td>
                        @if (sale.IsVoided)
                        {
                            <span class="badge-void">Voided</span>
                        }
                        else
                        {
                            <span class="badge-paid">Completed</span>
                        }
                    </td>
                    <td>
                        <div class="actions">
                            <a class="btn btn-view" href="/Sales/Receipt/@sale.Id">View</a>
                            <a class="btn btn-download" href="/Sales/DownloadReceipt/@sale.Id">Download</a>

                            @if (!sale.IsVoided)
                            {
                                <form method="post" action="/Sales/Void/@sale.Id" onsubmit="return confirm('Void this sale and return stock?')">
                                    <button class="btn btn-void" type="submit">Void</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function filterTable() {
        let value = document.getElementById("searchBox").value.toLowerCase();
        let rows = document.querySelectorAll("#salesTable tbody tr");

        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
        });
    }
</script>