@model List<Oswald_POS.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<style>
    .page-grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 20px;
    }

    .panel {
        background: white;
        border-radius: 10px;
        padding: 22px;
        border: 1px solid #dbe1ea;
        box-shadow: 0 8px 24px rgba(15,23,42,.06);
    }

    input, button {
        width: 100%;
        box-sizing: border-box;
        padding: 12px;
        margin-bottom: 10px;
        border-radius: 7px;
        border: 1px solid #cbd5e1;
    }

    button {
        border: none;
        background: #2563eb;
        color: white;
        font-weight: 800;
        cursor: pointer;
    }

    .search {
        margin-bottom: 15px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #f8fafc;
        color: #475569;
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #e5e7eb;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #e5e7eb;
    }

    .credit {
        font-weight: 800;
        color: #dc2626;
    }

    .actions {
        display: flex;
        gap: 8px;
    }

    .small-btn {
        width: auto;
        padding: 8px 10px;
        margin: 0;
    }

    .delete {
        background: #dc2626;
    }

    @@media(max-width: 1000px) {
        .page-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-grid">
    <div class="panel">
        <h2>Add Customer</h2>

        <form method="post" action="/Customers/Create">
            <input name="FullName" placeholder="Full name" required />
            <input name="Phone" placeholder="Phone number" />
            <input name="CreditBalance" type="number" step="0.01" placeholder="Credit balance" value="0" />

            <button type="submit">Save Customer</button>
        </form>
    </div>

    <div class="panel">
        <h2>Customer List</h2>

        <input class="search" id="searchBox" placeholder="Search customer..." onkeyup="filterCustomers()" />

        <table id="customersTable">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Credit Balance</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var customer in Model)
                {
                    var updateFormId = "updateCustomer" + customer.Id;

                    <tr>
                        <td>
                            <input form="@updateFormId" name="Id" type="hidden" value="@customer.Id" />
                            <input form="@updateFormId" name="FullName" value="@customer.FullName" />
                        </td>

                        <td>
                            <input form="@updateFormId" name="Phone" value="@customer.Phone" />
                        </td>

                        <td>
                            <input form="@updateFormId" name="CreditBalance" type="number" step="0.01" value="@customer.CreditBalance" />
                            <div class="credit">UGX @customer.CreditBalance.ToString("N0")</div>
                        </td>

                        <td>
                            <div class="actions">
                                <form id="@updateFormId" method="post" action="/Customers/Update"></form>

                                <button form="@updateFormId" class="small-btn" type="submit">Update</button>

                                <form method="post" action="/Customers/Delete/@customer.Id" onsubmit="return confirm('Delete this customer?')">
                                    <button class="small-btn delete" type="submit">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function filterCustomers() {
        let value = document.getElementById("searchBox").value.toLowerCase();
        let rows = document.querySelectorAll("#customersTable tbody tr");

        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
        });
    }
</script>