@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Oswald POS - Login</title>
    <style>
        body {
            margin: 0;
            font-family: Segoe UI, Arial;
            background: linear-gradient(135deg, #111827, #312e81);
            height: 100vh;
            display: flex;
            color: white;
        }

        .left {
            flex: 1;
            padding: 80px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            color: #111827;
            width: 380px;
            padding: 35px;
            border-radius: 22px;
            box-shadow: 0 20px 50px rgba(0,0,0,.35);
        }

        input, button {
            width: 100%;
            padding: 14px;
            margin-top: 14px;
            border-radius: 12px;
            border: 1px solid #ddd;
            font-size: 15px;
        }

        button {
            background: #4f46e5;
            color: white;
            border: none;
            font-weight: bold;
            cursor: pointer;
        }

        .error {
            color: #dc2626;
            margin-top: 12px;
        }
    </style>
</head>
<body>
    <div class="left">
        <h1>Oswald POS</h1>
        <h2>Modern Point of Sale System</h2>
        <p>Manage products, sales, customers, workers and receipts from one clean dashboard.</p>
    </div>

    <div class="right">
        <form class="card" method="post">
            <h2>Login</h2>

            <input name="username" placeholder="Username" required />
            <input name="password" type="password" placeholder="Password" required />

            <button type="submit">Login</button>

            @if (ViewBag.Error != null)
            {
                <div class="error">@ViewBag.Error</div>
            }

            <p>Default: admin / admin123</p>
        </form>
    </div>
</body>
</html>