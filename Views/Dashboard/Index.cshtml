@model Oswald_POS.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";

    decimal maxSale = new[]
    {
        Model.MondaySales,
        Model.TuesdaySales,
        Model.WednesdaySales,
        Model.ThursdaySales,
        Model.FridaySales,
        Model.SaturdaySales,
        Model.SundaySales
    }.Max();

    if (maxSale == 0)
    {
        maxSale = 1;
    }
}

<style>
    .cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 22px;
    }

    .card {
        padding: 24px;
        border-radius: 10px;
        color: white;
        box-shadow: 0 10px 25px rgba(15,23,42,.12);
    }

    .blue { background: linear-gradient(135deg, #2563eb, #1e40af); }
    .green { background: linear-gradient(135deg, #16a34a, #166534); }
    .orange { background: linear-gradient(135deg, #f97316, #c2410c); }
    .purple { background: linear-gradient(135deg, #7c3aed, #4c1d95); }

    .card h2 {
        margin: 0;
        font-size: 28px;
    }

    .card p {
        margin-bottom: 0;
        opacity: .9;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1.4fr .8fr;
        gap: 20px;
    }

    .panel {
        background: white;
        border-radius: 10px;
        padding: 22px;
        border: 1px solid #dbe1ea;
        box-shadow: 0 8px 24px rgba(15,23,42,.06);
        margin-bottom: 20px;
    }

    .bar-row {
        display: grid;
        grid-template-columns: 45px 1fr 120px;
        align-items: center;
        gap: 12px;
        margin: 14px 0;
    }

    .bar {
        height: 20px;
        background: #e5e7eb;
        border-radius: 100px;
        overflow: hidden;
    }

    .fill {
        height: 100%;
        background: linear-gradient(90deg, #2563eb, #7c3aed);
        border-radius: 100px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #f8fafc;
        color: #475569;
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #e5e7eb;
    }

    td {
        padding: 12px;
        border-bottom: 1px solid #e5e7eb;
    }

    .quick-actions {
        display: grid;
        gap: 10px;
    }

    .quick-actions a {
        display: block;
        text-decoration: none;
        padding: 14px;
        border-radius: 8px;
        background: #f8fafc;
        color: #111827;
        border: 1px solid #e5e7eb;
        font-weight: 700;
    }

    .quick-actions a:hover {
        background: #2563eb;
        color: white;
    }

    .product-pill {
        padding: 10px;
        background: #f8fafc;
        border-radius: 8px;
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .low {
        color: #dc2626;
        font-weight: 900;
    }

    @@media(max-width: 1000px) {
        .cards, .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<h1>Welcome back 👋</h1>
<p>Here is today’s Oswald POS summary from the database.</p>

<div class="cards">
    <div class="card blue">
        <h2>UGX @Model.TodaySales.ToString("N0")</h2>
        <p>Today Sales</p>
    </div>

    <div class="card green">
        <h2>@Model.TotalProducts</h2>
        <p>Total Products</p>
    </div>

    <div class="card orange">
        <h2>@Model.LowStockProducts</h2>
        <p>Low Stock Products</p>
    </div>

    <div class="card purple">
        <h2>@Model.TotalCustomers</h2>
        <p>Customers</p>
    </div>
</div>

<div class="dashboard-grid">
    <div>
        <div class="panel">
            <h2>Weekly Sales Chart</h2>

            <div class="bar-row">
                <strong>Mon</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.MondaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.MondaySales.ToString("N0")</span>
            </div>

            <div class="bar-row">
                <strong>Tue</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.TuesdaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.TuesdaySales.ToString("N0")</span>
            </div>

            <div class="bar-row">
                <strong>Wed</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.WednesdaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.WednesdaySales.ToString("N0")</span>
            </div>

            <div class="bar-row">
                <strong>Thu</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.ThursdaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.ThursdaySales.ToString("N0")</span>
            </div>

            <div class="bar-row">
                <strong>Fri</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.FridaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.FridaySales.ToString("N0")</span>
            </div>

            <div class="bar-row">
                <strong>Sat</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.SaturdaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.SaturdaySales.ToString("N0")</span>
            </div>

            <div class="bar-row">
                <strong>Sun</strong>
                <div class="bar">
                    <div class="fill" style="width:@((Model.SundaySales / maxSale) * 100)%"></div>
                </div>
                <span>UGX @Model.SundaySales.ToString("N0")</span>
            </div>
        </div>

        <div class="panel">
            <h2>Recent Sales</h2>

            <table>
                <tr>
                    <th>Receipt</th>
                    <th>Customer</th>
                    <th>Cashier</th>
                    <th>Total</th>
                    <th>Date</th>
                </tr>

                @if (!Model.RecentSales.Any())
                {
                    <tr>
                        <td colspan="5">No sales yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var sale in Model.RecentSales)
                    {
                        <tr>
                            <td>
                                <a href="/Sales/Receipt/@sale.Id">@sale.ReceiptNumber</a>
                            </td>
                            <td>@(sale.Customer?.FullName ?? "Walk-in")</td>
                            <td>@(sale.Worker?.FullName ?? "Unknown")</td>
                            <td>UGX @sale.TotalAmount.ToString("N0")</td>
                            <td>@sale.SaleDate.ToString("dd MMM yyyy HH:mm")</td>
                        </tr>
                    }
                }
            </table>
        </div>
    </div>

    <div>
        <div class="panel">
            <h2>Quick Actions</h2>

            <div class="quick-actions">
                <a href="/Sales">Open POS Sales</a>

                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a href="/Products">Manage Products</a>
                    <a href="/Categories">Manage Categories</a>
                    <a href="/Customers">Manage Customers</a>
                    <a href="/Sales/History">View Sales History</a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Workers">Manage Workers</a>
                }
            </div>
        </div>

        <div class="panel">
            <h2>Top Products</h2>

            @if (!Model.TopProducts.Any())
            {
                <p>No top products yet.</p>
            }
            else
            {
                @foreach (var product in Model.TopProducts)
                {
                    <div class="product-pill">
                        <strong>@product.ProductName</strong>
                        <span>@product.QuantitySold sold</span>
                    </div>
                }
            }
        </div>

        <div class="panel">
            <h2>Low Stock Items</h2>

            @if (!Model.LowStockItems.Any())
            {
                <p>No low stock items.</p>
            }
            else
            {
                @foreach (var product in Model.LowStockItems)
                {
                    <div class="product-pill">
                        <strong>@product.Name</strong>
                        <span class="low">@product.StockQuantity left</span>
                    </div>
                }
            }
        </div>
    </div>
</div>